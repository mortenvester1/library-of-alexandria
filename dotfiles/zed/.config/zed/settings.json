// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
// This doesn't work rigt now? Break files
{
  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "context_servers": {},
  "ssh_connections": [
    {
      "host": "jetson",
      "args": [],
      "projects": [
        {
          "paths": ["/home/jetson/git/library-of-alexandria"],
        },
      ],
    },
  ],
  "language_models": {
    "ollama": {
      "api_url": "http://orin-nano.local:11434",
    },
    "lmstudio": {
      "api_url": "http://localhost:1234/api/v1",
    },
  },
  "edit_predictions": {
    "provider": "open_ai_compatible_api",
    "mode": "subtle",
    "open_ai_compatible_api": {
      "api_url": "http://localhost:1234/api/v1/completions",
      "model": "gemma-4-26b-a4b",
      "prompt_format": "infer",
      "max_output_tokens": 64,
    },
  },
  "theme": "Dracula",
  "base_keymap": "Atom",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "show_whitespaces": "all",
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "default_profile": "write",
    "use_modifier_to_send": true,
    "expand_edit_card": true,
    "default_model": {
      "model": "claude-sonnet-4-6",
      "provider": "claude-acp",
    },
    "inline_assistant_model": {
      "model": "claude-haiku-4-5",
      "provider": "claude-acp",
    },
  },
  "tabs": {
    "file_icons": true,
    "close_position": "right",
  },
  "colorize_brackets": true,
  "preferred_line_length": 120,
  "format_on_save": "on",
  "soft_wrap": "editor_width",
  "file_scan_exclusions": ["**/.git", ".DS_Store", ".ropeproject", ".ruff_cache", ".pytest_cache", "__pycache__"],
  "terminal": {
    "copy_on_select": true,
    "working_directory": "current_project_directory",
    "detect_venv": {
      "on": {
        "activate_script": "default",
        "venv_name": ".venv",
      },
    },
  },
  "file_types": {
    "Shell Script": ["*bash", "*sh", "*zsh*", ".envrc"],
    "Dockerfile": ["Dockerfile*"],
    "Groovy": ["*Jenkinsfile*"],
    "JSON": ["*.json", "*.avro"],
  },
  "languages": {
    "LaTeX": {
      "tab_size": 2,
    },
    "Java": {
      "format_on_save": "off",
      "formatter": {
        "external": {
          "command": "mvn formatter:fmt",
        },
      },
    },
    "JSON": {
      "tab_size": 2,
    },
    "HTML": {
      "tab_size": 2,
    },
    "Groovy": {
      "tab_size": 2,
    },
    "JSONC": {
      "tab_size": 2,
    },
    "XML": {
      "tab_size": 2,
    },
    "YAML": {
      "tab_size": 2,
    },
    "Shell Script": {
      "tab_size": 2,
      "hard_tabs": false,
    },
    "SQL": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "sql-formatter",
        },
      },
    },
  },
  "inlay_hints": {
    "enabled": false,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "toggle_on_modifiers_press": {
      "alt": true,
    },
  },
  "indent_guides": {
    "coloring": "indent_aware",
  },
  "auto_install_extensions": {
    "dockerfile": true,
    "dracula": true,
    "git-firefly": true,
    "groovy": true,
    "html": true,
    "ini": true,
    "java": true,
    "jq": true,
    "just": true,
    "latex": true,
    "make": true,
    "rego": true,
    "ruff": true,
    "scala": true,
    "sql": true,
    "swift": true,
    "terraform": true,
    "toml": true,
    "xml": true,
  },
  "minimap": {
    "show": "always",
    "thumb": "always",
    "thumb_border": "left_open",
    "current_line_highlight": "all",
  },
  "notification_panel": { "button": false },
  "debugger": { "button": false },
  "collaboration_panel": { "button": false },
  "diagnostics": { "button": false },
  "lsp": {
    "basedpyright": {
      "settings": {
        "basedpyright.analysis": {
          "typeCheckingMode": "basic",
          "diagnosticMode": "openFilesOnly",
          "inlayHints": {
            "callArgumentNames": false,
          },
        },
      },
    },
  },
}
