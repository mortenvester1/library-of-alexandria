{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": ["openai", "anthropic", "amazon-bedrock", "opencode"],
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://localhost:1234/v1",
        "num_ctx": "65536"
      },
      "models": {
        "google/gemma-4-e2b": { "name": "gemma-4-e2b" },
        "google/gemma-4-e4b": { "name": "gemma-4-e4b" },
        "google/gemma-4-26b-a4b": { "name": "gemma-4-26b-a4b" },
        "nvidia/nemotron-3-nano": { "name": "nemotron-3-nano" },
        "nvidia/nemotron-3-nano-4b": { "name": "nemotron-3-nano-4b" },
        "qwen/qwen3.5-9b": { "name": "qwen3.5-9b" },
        "qwen/qwen3.5-35b-a3b": { "name": "qwen3.5-35b-a3b" }
      }
    }
  },
  "model": "lmstudio/google/gemma-4-26b-a4b",
  "small_model": "lmstudio/google/gemma-4-26b-a4b",
  "permission": {
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "ls *": "allow",
      "git status": "allow",
      "git diff": "allow"
    },
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "question": "allow",
    "read": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "webfetch": "ask",
    "write": "allow"
  }
}
